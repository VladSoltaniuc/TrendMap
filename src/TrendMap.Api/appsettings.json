{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Trends": {
    "NodeExecutable": "node",
    "NodeOptions": "--use-system-ca",
    "CacheMinutes": 60,
    "DefaultTimeframe": "today 5-y",
    "FetchTimeoutSeconds": 45,
    "RateLimitPerMinute": 30
  }
}
